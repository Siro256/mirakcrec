{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
        "customType": "regex",
        "fileMatch": [
          "(^|/)devcontainer\\.json$"
        ],
        "matchStrings": [
          "^[\\t ]*\\\"version\\\"[\\t ]*:[\\t ]*\\\"(?<currentValue>.+)\\\",\\s*\\/\\/ renovate datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?$"
        ]
    }
  ]
}
