{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    // devcontainer features option
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)devcontainer\\.json$/"
      ],
      "matchStrings": [
        "\\\"version\\\"[\\t ]*:[\\t ]*\\\"(?<currentValue>.+)\\\",\\s*\\/\\/ renovate datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?"
      ]
    },
  ]
}
